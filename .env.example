# DeepSeek
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_MODE=chat
SELECTION_MODEL=deepseek-v4-flash
CLASSIFICATION_MODEL=deepseek-v4-flash
LLM_JSON_MODE=json_object
OPENAI_MAX_TOKENS=8192

# Pipeline
TARGET_LANGUAGE=zh-CN
TIMEZONE=Asia/Shanghai
MAX_CANDIDATES=80
MAX_SELECTED=15
MIN_MATCH_SCORE=50
TRANSLATION_BATCH_SIZE=3
DRY_RUN=1
DB_PATH=data/strategies.db
ARCHIVE_PATH=docs/strategy_archive.md

# Optional: GitHub Search API (higher rate limits)
GITHUB_TOKEN=

# Email (QQ SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_qq@qq.com
SMTP_PASSWORD=your_qq_auth_code
EMAIL_FROM=your_qq@qq.com
EMAIL_TO=your_qq@qq.com
EMAIL_SUBJECT=Quant Strategy Digest
